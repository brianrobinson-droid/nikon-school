# DATABASE_URL — local PostgreSQL (project decision: no Neon, no cloud DB)
# This project uses a local PostgreSQL instance for all development.
# For production/Vercel deployment, a hosted Postgres URL will be used when that story is implemented.
DATABASE_URL=postgresql://localhost:5432/your_database_name

# Random 32+ char string for Payload session encryption
PAYLOAD_SECRET=your-random-secret-min-32-chars

# App URL for CORS, metadata, links — no trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Vercel Blob — create a Blob store in your Vercel project dashboard (Storage tab)
# Token format: vercel_blob_rw_<store-id>_<random>
# Required for local dev AND production — no local substitute exists
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_<store-id>_<random>

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE
